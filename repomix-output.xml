                    </button>
                    {ticketSeleccionado.estado === 'CERRADO' ? (
                      <div className="ticket-cerrado-badge">✅ Ticket Cerrado</div>
                    ) : (
                      <>
                        {!ticketSeleccionado.asignadoA && (
