                  <div className="info-item">
                    <label>📞 Teléfono:</label>
                    <span>{ticketSeleccionado.phoneNumber}</span>
                  </div>
                  <div className="info-item">
                    <label>🚗 Placa:</label>
                    <span>{ticketSeleccionado.placa}</span>
                  </div>
                  <div className="info-item">
                    <label>🆔 Cédula:</label>
                    <span>{ticketSeleccionado.cedula}</span>
                  </div>
                  <div className="info-item">
                    <label>📊 Ticket del Cliente:</label>
