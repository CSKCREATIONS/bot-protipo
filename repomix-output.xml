                  <div className="info-item">
                    <label>📅 Fecha creación:</label>
                    <span>{formatearFecha(ticketSeleccionado.fechaCreacion)}</span>
                  </div>
                  {ticketSeleccionado.fechaFinalizacion && (
                    <div className="info-item">
